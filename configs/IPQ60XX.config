CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
# CONFIG_TARGET_MULTI_PROFILE is not set

# ==========================================
# 1. 只编译 jdcloud_re-ss-01（亚瑟）
# ==========================================
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y

# 显式关闭其他京东云设备（覆盖 JDCloud.config 中的开启）
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-07 is not set
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_ax6600 is not set

# ==========================================
# 2. 加入 tailscale（解决依赖问题）
# ==========================================
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_tailscale=y
CONFIG_PACKAGE_luci-app-tailscale-community=y
CONFIG_PACKAGE_luci-i18n-tailscale-community-zh-cn=y

# ==========================================
# 3. 关闭不需要的软件（根据你的需求调整）
# ==========================================
# 关闭 ACME 证书
# CONFIG_PACKAGE_luci-app-acme is not set
# CONFIG_PACKAGE_acme-acmesh-dnsapi is not set

# 关闭动态 DNS
# CONFIG_PACKAGE_luci-app-ddns is not set
# CONFIG_PACKAGE_ddns-scripts-cloudflare is not set

# 关闭 frp（内网穿透）
# CONFIG_PACKAGE_luci-app-frps is not set
# CONFIG_PACKAGE_luci-app-frpc is not set

# 关闭 WireGuard（如果你用 Tailscale 替代）
# CONFIG_PACKAGE_luci-proto-wireguard is not set

# ==========================================
# 4. 硬件相关配置（保留）
# ==========================================
CONFIG_ATH11K_MEM_PROFILE_512M=y
CONFIG_NSS_FIRMWARE_VERSION_11_4=y
